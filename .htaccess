RewriteEngine On
# Remove .php extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]
# Redirect old .php URLs to extensionless
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\.]+)\.php\ HTTP/
RewriteRule ^ /%1 [R=301,L]
# Handle api subdir
RewriteCond %{REQUEST_URI} ^/api/([^\.]+)$
RewriteRule ^api/([^\.]+)$ api/$1.php [NC,L]
Options -Indexes
# Protect sensitive files
<FilesMatch "^(\.env|\.gitignore|\.htaccess|composer\.json|composer\.lock|config\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>
# Deny access to private directories
RewriteRule ^(cache|import_files|vendor)/ - [F,L]